# ── Confluence Integration ─────────────────────────────────────────────────────
# Same URL, email and token as Jira — only the space key is new
# Find your space key: Confluence → Space Settings → Space Key
CONFLUENCE_SPACE=TECH

# ── Jira Integration ───────────────────────────────────────────────────────────
# Create an API token at: Atlassian → Account Settings → Security → API tokens
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_TOKEN=your-atlassian-api-token
JIRA_PROJECT=PROJ

# ── GitHub Integration ─────────────────────────────────────────────────────────
# Create a Personal Access Token at: GitHub → Settings → Developer settings → PAT
# Required scopes: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=your-org/your-repo-name
GITHUB_BRANCH=main
GITHUB_MV_FOLDER=mv_source

# ── LLM & Embeddings (Ollama) ──────────────────────────────────────────────────
LLM_MODEL=qwen2.5-coder:14b
EMBED_MODEL=nomic-embed-text

# ── Local Paths ────────────────────────────────────────────────────────────────
SOURCE_DIR=./mv_source
DOCS_DIR=./documents
CHROMA_PATH=./chroma_db
GRAPH_PATH=./graph.json
