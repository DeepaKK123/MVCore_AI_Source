# ══════════════════════════════════════════════════════════════════════════════
# MVCore — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Credentials & secrets (NEVER commit) ──────────────────────────────────────
.env
*.token
*.secret
secrets.json

# ── Python bytecode & build artifacts ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Generated / runtime data (rebuilt by setup.py or sync scripts) ─────────────
chroma_db/
chroma_db_backup/
graph.json
.sync_meta.json

# ── MV BASIC source files (synced separately from the client's own git repo) ───
mv_source/

# ── Large binary documents (PDF syntax manuals — too large for git) ────────────
# Commit only the small dict layout .txt files in documents/dict_file_layout/
documents/mv_syntax/
*.pdf

# ── Streamlit cache ────────────────────────────────────────────────────────────
.streamlit/

# ── Pytest & testing cache ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.coveragerc

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Database files ─────────────────────────────────────────────────────────────
*.sqlite3
*.db

# ── OS-generated files ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── VS Code (personal IDE settings — commit only shared workspace config) ───────
.vscode/

# ── JetBrains IDEs ────────────────────────────────────────────────────────────
.idea/
*.iml

# ── Jupyter Notebooks (if any) ────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Temporary files ────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*~
